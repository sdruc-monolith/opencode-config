{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "duckduckgo": {
      "type": "local",
      "command": [
        "uvx",
        "duckduckgo-mcp-server"
      ]
    },
    "mon-atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "cw-atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "glean_default": {
      "type": "remote",
      "url": "https://coreweave-be.glean.com/mcp/default"
    },
    "alphaxiv": {
      "type": "remote",
      "url": "https://api.alphaxiv.org/mcp/v1"
    },
    "zotero": {
      "type": "local",
      "command": [
        "zotero-mcp"
      ],
      "timeout": 120000,
      "environment": {
        "ZOTERO_LOCAL": "{env:ZOTERO_LOCAL}",
        "ZOTERO_API_KEY": "{env:ZOTERO_API_KEY}",
        "ZOTERO_LIBRARY_ID": "{env:ZOTERO_LIBRARY_ID}",
        "ZOTERO_LIBRARY_TYPE": "{env:ZOTERO_LIBRARY_TYPE}"
      }
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"]
    }
  },
  "experimental": {
    "openTelemetry": true
  }
}
